# Maintainer: Zerogoki00 <ayanami@nerv.un.org>
pkgname=jp-cards
pkgver=0.2.9
pkgrel=1
pkgdesc="Qt 6 printable PDF of double-sided Japanese flashcards generator"
arch=('x86_64')
url="https://github.com/Zerogoki00/jp-cards"
license=('GPL-3.0-or-later' 'custom:OFL-1.1')
depends=('qt6-base' 'qt6-webengine') 
makedepends=('cmake' 'ninja' 'python-fonttools')
source=(
    "$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz"
    "NotoSansJP-VF.ttf::https://github.com/notofonts/noto-cjk/raw/main/Sans/Variable/TTF/Subset/NotoSansJP-VF.ttf"
)
# Run `updpkgsums` after editing pkgver to refresh these.
sha256sums=('SKIP'
            'SKIP')

prepare() {
    # CMake hard-fails without the bundled font; stage it before configure.
    fonttools varLib.instancer "$srcdir/NotoSansJP-VF.ttf" wght=400 \
        --static --update-name-table \
        --output "$srcdir/$pkgname-$pkgver/resources/fonts/NotoSansJP-Regular.ttf"
}

build() {
    cd "$pkgname-$pkgver"
    cmake --preset linux-release \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_BUILD_TYPE=Release
    cmake --build --preset linux-release
}

package() {
    cd "$pkgname-$pkgver"
    install -Dm755 "build/linux-release/jp-cards" \
        "$pkgdir/usr/bin/jp-cards"
    install -Dm644 packaging/jp-cards.desktop \
        "$pkgdir/usr/share/applications/jp-cards.desktop"
    install -Dm644 LICENSE \
        "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
